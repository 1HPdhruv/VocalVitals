# VocalVitals Environment Variables

# ===========================================
# API Keys
# ===========================================
ANTHROPIC_API_KEY=
HF_TOKEN=

# ===========================================
# Twilio (Phone Call Integration)
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# WebSocket URL for Twilio Media Streams (use ngrok for local dev)
STREAM_WEBSOCKET_URL=wss://yourdomain.com/twilio/stream
# Default number to forward calls to
DEFAULT_FORWARD_NUMBER=

# ===========================================
# AWS S3 (Audio Storage)
# ===========================================
S3_BUCKET_NAME=vocalvitals-audio
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ===========================================
# Database
# ===========================================
# For Docker: postgresql://vocalvitals:vocalvitals@postgres:5432/vocalvitals
# For local: Uses SQLite by default (no config needed)
DATABASE_URL=

# ===========================================
# Redis (Celery Task Queue)
# ===========================================
# For Docker: redis://redis:6379/0
# For local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ===========================================
# Email Notifications (SendGrid)
# ===========================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@vocalvitals.ai

# ===========================================
# Whisper (Speech Recognition)
# ===========================================
WHISPER_MODEL=base

# ===========================================
# Firebase (Optional - Legacy)
# ===========================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=
FIREBASE_WEB_API_KEY=

# ===========================================
# Misc
# ===========================================
NOMINATIM_USER_AGENT=vocal-vitals-app/1.0

# ===========================================
# Flower (Celery Monitoring) - Docker only
# ===========================================
FLOWER_USER=admin
FLOWER_PASSWORD=admin
